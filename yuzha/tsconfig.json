{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../shared/*"],
      "@yuzha/timestamp": ["../timestamp/src/components/TimestampScreen.tsx"],
      "@yuzha/manga-reader": ["../manga/src/App.tsx"]
    }
  },
  "references": [
    { "path": "../timestamp" },
    { "path": "../manga" }
  ],
  "include": ["src", "env.d.ts", "index.html", "../shared"]
}
